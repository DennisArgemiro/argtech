rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read only if visible flag is set
    match /footer_info/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /site_texts/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /services/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /carousel_slides/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /navigation/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /contacts/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /projects/{doc} {
      allow read: if resource.data.visible == true;
    }
    match /images/{doc} {
      allow read: if resource.data.visible == true;
    }

    // Contact messages: anyone can create (with validation), only admins can read
    match /contact_messages/{doc} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'company', 'service', 'message', 'createdAt', 'read']);
      allow read, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Admin full access (authenticated users with admin custom claim)
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
